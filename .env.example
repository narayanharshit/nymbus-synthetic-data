# Copy to .env.local to enable the Claude interpreter. Both are optional —
# with no key set, the app uses the built-in deterministic heuristic interpreter
# and still generates, validates, and exports end-to-end.

# Your Anthropic API key. Read ONLY by the server route (/api/interpret);
# never sent to the browser, never committed (.env* is git-ignored).
ANTHROPIC_API_KEY=

# Optional model override. Defaults to claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8
